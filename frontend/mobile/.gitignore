# =========================================================
# Android / Kotlin 모바일 프로젝트용 .gitignore
# =========================================================

# ----- Gradle 빌드 산출물 -----
# Gradle 빌드 시 생성되는 결과물 디렉터리 (APK, 클래스 파일 등)
**/build/
# Gradle 데몬 캐시 및 로컬 작업 파일
.gradle/
# 빌드 출력 디렉터리
**/out/
**/bin/
# 자동 생성 코드 (Kapt, KSP, ViewBinding 등)
**/generated/

# ----- 로컬 환경 설정 -----
# SDK 경로 등 로컬 머신 전용 설정 (절대 커밋 금지)
local.properties
# Keystore (서명용 키, 보안상 절대 커밋 금지)
*.jks
*.keystore
# 환경 변수 파일
.env
.env.local

# ----- IntelliJ / Android Studio IDE 설정 -----
# IDE 사용자별 설정 디렉터리 (워크스페이스, 디바이스 캐시 등 개인 환경)
.idea/
# 단, 공유가 유용한 일부 설정은 예외로 추적 허용하고 싶을 때 아래 주석 해제
# !.idea/codeStyles/
# !.idea/inspectionProfiles/

# IntelliJ 모듈/프로젝트 파일
*.iml
*.ipr
*.iws

# ----- 캡처 / 프로파일링 -----
# Android Studio Profiler 캡처 파일
captures/

# ----- 네이티브 디버그 심볼 -----
# NDK 빌드 산출물
.externalNativeBuild/
.cxx/

# ----- 로그 -----
*.log

# ----- OS 생성 파일 -----
# macOS
.DS_Store
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# ----- 기타 임시 파일 -----
*.swp
*.bak
*.tmp
