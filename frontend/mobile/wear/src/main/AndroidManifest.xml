<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Wear OS -->
    <uses-feature android:name="android.hardware.type.watch" />

    <!-- 마이크 (STT 음성 녹음) -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- 바디 센서 (제스처 감지) -->
    <uses-permission android:name="android.permission.BODY_SENSORS" />

    <!-- 네트워크 -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- 알람/알림 -->
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <!-- Android 13+(Wear OS 4+) 에서 정확한 알람 자동 부여 — 알람이 핵심 기능인 앱용. -->
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- 손목 제스처용 ForegroundService -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.HIGH_SAMPLING_RATE_SENSORS" />

    <application
        android:name=".WearApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:theme="@android:style/Theme.DeviceDefault">

        <!-- 폰 앱과 연동 필요 (standalone = false) -->
        <meta-data
            android:name="com.google.android.wearable.standalone"
            android:value="false" />

        <activity
            android:name=".WearMainActivity"
            android:exported="true"
            android:taskAffinity="">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- s09 수액 종료 풀스크린 알람 호스트 -->
        <activity
            android:name=".alarm.IvAlarmActivity"
            android:exported="false"
            android:showOnLockScreen="true"
            android:turnScreenOn="true"
            android:launchMode="singleTask"
            android:taskAffinity=""
            android:excludeFromRecents="true" />

        <!-- s13 STT 타이머 풀스크린 알람 호스트 -->
        <activity
            android:name=".alarm.SttAlarmActivity"
            android:exported="false"
            android:showOnLockScreen="true"
            android:turnScreenOn="true"
            android:launchMode="singleTask"
            android:taskAffinity=""
            android:excludeFromRecents="true" />

        <!-- 환자 요청 HIGH/CRITICAL 풀스크린 알람 호스트 -->
        <activity
            android:name=".alarm.PatientCallAlarmActivity"
            android:exported="false"
            android:showOnLockScreen="true"
            android:turnScreenOn="true"
            android:launchMode="singleTask"
            android:taskAffinity=""
            android:excludeFromRecents="true" />

        <!-- AlarmManager → 풀스크린 알림 발행용 Receiver -->
        <receiver
            android:name=".alarm.SttAlarmReceiver"
            android:exported="false" />

        <!-- 손목 제스처 ForegroundService — 로그인 동안 상시 자이로 listening -->
        <service
            android:name=".gesture.GestureService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="wrist-gesture-shortcut" />
        </service>

        <!-- 폰-워치 DataLayer 메시지 수신 서비스 -->
        <service
            android:name=".data.remote.wearable.WearDataListenerService"
            android:exported="true">
            <intent-filter>
                <action android:name="com.google.android.gms.wearable.DATA_CHANGED" />
                <action android:name="com.google.android.gms.wearable.MESSAGE_RECEIVED" />
                <data android:scheme="wear" android:host="*" />
            </intent-filter>
        </service>

        <!-- Firebase Cloud Messaging 수신 서비스 (워치 직접 푸시) -->
        <service
            android:name=".data.remote.fcm.WearFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

    </application>

</manifest>
