  "safety_rules": {
    "no_downgrade": {
      "description": "키워드 매칭으로 CRITICAL 판정된 건은 LLM이 등급을 낮출 수 없음",
      "example": {
        "input": "숨이 좀 답답한데 괜찮은 것 같아요",
        "keyword_match": "숨 + 답답 → CRITICAL",
        "llm_override": false,
        "final_priority": "critical"
      }
    },
    "streaming_early_detection": {
      "description": "STT 스트리밍 중간 텍스트에서 CRITICAL 키워드 감지 시 즉시 알림",
      "example": {
        "partial_text": "숨이 안 쉬어—",
        "keyword_detected": "숨이 안",
        "action": "즉시 CRITICAL 알림 트리거"
      }
    },
    "compound_upgrade": {
      "description": "단독으로는 HIGH이지만, 특정 조합 시 CRITICAL로 상향",
      "rules": [
        {
          "condition": "infection_signs >= 2",
